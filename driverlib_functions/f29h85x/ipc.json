      "returnType": "bool",
      "functionContent": "{\n    bool ret;\n\n    //\n    // Check whether the flags are not busy\n    //\n    if((HWREG(IPC_REG_FLG(ipcChannel)) & flags) == 0U)\n    {\n        ret = true;\n\n        //\n        // Update the command registers\n        //\n        HWREG(IPC_REG_SENDCOM(ipcChannel))  = command;\n        HWREG(IPC_REG_SENDDATA(ipcChannel)) = data;\n        HWREG(IPC_REG_SENDADDR(ipcChannel)) = addr;\n\n        //\n        // Set the flags to indicate the remote core\n        //\n        HWREG(IPC_REG_SET(ipcChannel)) = flags;\n    }\n    else\n    {\n        ret = false;\n    }\n\n    return(ret);\n}\n",
      "functionContentWithoutFormatting": "{ bool ret; // // Check whether the flags are not busy // if((HWREG(IPC_REG_FLG(ipcChannel)) & flags) == 0U) { ret = true; // // Update the command registers // HWREG(IPC_REG_SENDCOM(ipcChannel)) = command; HWREG(IPC_REG_SENDDATA(ipcChannel)) = data; HWREG(IPC_REG_SENDADDR(ipcChannel)) = addr; // // Set the flags to indicate the remote core // HWREG(IPC_REG_SET(ipcChannel)) = flags; } else { ret = false; } return(ret); }",
